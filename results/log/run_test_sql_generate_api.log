    t1."股票代码",
    ROUND((CAST(t1."收盘价(元)" AS REAL) - CAST(t2."昨收盘(元)" AS REAL)) / CAST(t2."昨收盘(元)" AS REAL) * 100, 2) AS "涨跌幅"
FROM
    "A股票日行情表" t1
JOIN
    "A股票日行情表" t2
    ON t1."股票代码" = t2."股票代码"
    AND t2."交易日" = '20210718'
JOIN
    "A股公司行业划分表" t3
    ON t1."股票代码" = t3."股票代码"
    AND t3."交易日期" = '20210719'
WHERE
    t1."交易日" = '20210719'
    AND t3."一级行业名称" = '消费者服务'
    AND t2."昨收盘(元)" <> 0
ORDER BY
    "涨跌幅" DESC
LIMIT 1;
