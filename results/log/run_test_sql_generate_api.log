question:  我想知道在2021年，摩根基金管理(中国)有限公司已发行的基金中，有多少只基金报告期期初基金总份额小于报告期期末基金总份额(使用每只基金当年最晚的定期报告数据计算)？
generated sql:
 SELECT COUNT(*)
FROM (
    SELECT f."基金代码"
    FROM "基金基本信息表" f
    INNER JOIN "基金规模变动表" s ON f."基金代码" = s."基金代码"
    WHERE f."管理人" = '摩根基金管理(中国)有限公司'
      AND s."定期报告所属年度" = 2021
      AND s."报告类型" IN ('年度报告', '中期报告')
    GROUP BY f."基金代码"
    HAVING MAX(s."截止日期") = (
        SELECT MAX(s2."截止日期")
        FROM "基金规模变动表" s2
        WHERE s2."基金代码" = f."基金代码"
          AND s2."定期报告所属年度" = 2021
          AND s2."报告类型" IN ('年度报告', '中期报告')
    )
) t
