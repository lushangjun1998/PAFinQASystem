WHERE 股票代码 = (
    SELECT 股票代码
    FROM 基金股票持仓明细表
    WHERE 基金简称 = '广发中证央企创新驱动ETF'
      AND 持仓日期 LIKE '2020%'
      AND 第N大重仓股 = 6
)
AND 交易日 BETWEEN (
    SELECT MIN(交易日)
    FROM A股票日行情表
    WHERE 股票代码 = (
        SELECT 股票代码
        FROM 基金股票持仓明细表
        WHERE 基金简称 = '广发中证央企创新驱动ETF'
          AND 持仓日期 LIKE '2020%'
          AND 第N大重仓股 = 6
    )
) AND (
    SELECT MAX(交易日)
